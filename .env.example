# 자람법 환경변수 템플릿
# 사용: cp .env.example .env → 실제 키 입력

# OpenAI (LLM 시나리오 분석, 옵션 — 미설정 시 LLM 단계 자동 비활성)
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini

# OpenRouter (대체 LLM, 옵션)
OPENROUTER_API_KEY=sk-or-v1-...

# 법제처 Open API (https://open.law.go.kr)
# 신청서: https://open.law.go.kr/LSO/openApi/cuAskUsage.do
# OC 파라미터에 본 키 사용
LAW_API_KEY=your_oc_key_here
# OC 키가 쿼리스트링에 실려 나가므로 https 고정. http를 넣어도 코드가 https로 승격한다.
LAW_API_BASE_URL=https://www.law.go.kr

# legalize-kr 저장소 (로컬 클론 경로, 상대/절대 모두 가능)
LEGALIZE_KR_PATH=./external/legalize-kr

# --- 독립 적대적 비평가 (OpenRouter) ---
# 부모가 읽을 AI 답변을 "다른 회사의 모델"이 검증한다. 답변을 쓴 모델에게 자기 답변을
# 검토시키면 같은 착각을 두 번 하므로, 반드시 다른 계열이어야 한다.
OPENROUTER_API_KEY=
JARAMLAW_CRITIC_MODEL=x-ai/grok-4.5
JARAMLAW_CRITIC_FALLBACK=anthropic/claude-sonnet-5
# 비평가는 질문·AI답변·법령을 외부(xAI/Anthropic)로 보낸다. 가족 프로필은 보내지 않는다.
# 제3자 전송이 부담스러우면 워크플로우 호출 시 enable_critic=False.
