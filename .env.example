# 자람법 환경변수 템플릿
# 사용: cp .env.example .env → 실제 키 입력

# OpenAI (LLM 시나리오 분석, 옵션 — 미설정 시 LLM 단계 자동 비활성)
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini

# OpenRouter (대체 LLM, 옵션)
OPENROUTER_API_KEY=sk-or-v1-...

# 법제처 Open API (https://open.law.go.kr)
# 신청서: https://open.law.go.kr/LSO/openApi/cuAskUsage.do
# OC 파라미터에 본 키 사용
LAW_API_KEY=your_oc_key_here
LAW_API_BASE_URL=http://www.law.go.kr

# legalize-kr 저장소 (로컬 클론 경로, 상대/절대 모두 가능)
LEGALIZE_KR_PATH=./external/legalize-kr
